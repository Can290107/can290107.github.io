rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{documentId} {
      allow read, write: if request.auth != null;
    }

    match /todos/{documentId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
